# Data Layer
# Controls which data source the app uses.
# "mock" — hardcoded data with simulated latency (default, no backend needed)
# "live" — fetches from a real API at NEXT_PUBLIC_API_URL
NEXT_PUBLIC_DATA_SOURCE=mock

# API Configuration (only required when DATA_SOURCE=live)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Branding (optional — override to apply client branding)
NEXT_PUBLIC_CLIENT_NAME=Prototype
